// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  // provider = "prisma-client"
  // output   = "../generated/prisma"
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 音乐项目用户表
model User {
  id        Int      @id @default(autoincrement()) // 自动递增的主键
  email     String   @unique                      // 唯一邮箱，用于登录
  username  String   @unique                      // 唯一用户名
  password  String                                // 加密后的密码
  avatar    String?                               // 头像 URL（可选）
  role      Role     @default(USER)               // 用户角色（默认普通用户）
  
  createdAt DateTime @default(now())              // 注册时间
  updatedAt DateTime @updatedAt                   // 资料最后更新时间

  // 未来扩展：一个用户可以拥有多个歌单 (Playlist)
  // playlists Playlist[] 
}

// 定义用户角色枚举
enum Role {
  USER
  ADMIN
}


// 歌曲模型
model Song {
  id          Int      @id @default(autoincrement())
  title       String
  duration    Int      // 时长（秒）
  filePath    String   // 音乐文件存储路径
  coverUrl    String?  // 封面图 URL
  playCount   Int      @default(0)  // 播放次数
  
  // 关联到歌手
  artistId    Int
  artist      Artist   @relation(fields: [artistId], references: [id])
  //相当于=> artist_id INT,FOREIGN KEY (artist_id) REFERENCES artist(id)
  
  // 关联到专辑
  albumId     Int?
  album       Album?   @relation(fields: [albumId], references: [id])

  createdAt   DateTime @default(now()) //插入时间，自动
  updatedAt   DateTime @updatedAt //更新时间，自动
}

// 歌手模型
model Artist {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  bio       String?
  avatar    String?
  songs     Song[]   // 一个歌手有多首歌曲,不是字段，只是映射
  albums    Album[]  // 一个歌手有多个专辑,不是字段，只是映射
}

// 专辑模型
model Album {
  id          Int      @id @default(autoincrement())
  title       String
  coverUrl    String?
  releaseDate DateTime?
  
  artistId    Int
  artist      Artist   @relation(fields: [artistId], references: [id])
  songs       Song[]   // 一个专辑有多首歌曲,不是字段，只是映射
}